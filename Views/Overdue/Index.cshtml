@model IEnumerable<LibraryManagement.Models.BorrowRecord>
@{
    ViewData["Title"] = "Danh sách Quá hạn";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-danger fw-bold mb-0">Quản lý Sách Quá hạn</h1>
    </div>

    @if (TempData["ReminderStatus"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-send-check me-2"></i> @TempData["ReminderStatus"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Sách & Độc giả</th>
                            <th>Ngày mượn / Hạn trả</th>
                            <th>Số ngày quá hạn</th>
                            <th>Tiền phạt hiện tại</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.Book?.Title</div>
                                    <div class="small text-muted">Độc giả: @item.User?.FullName</div>
                                    <div class="small text-muted">@item.User?.Email</div>
                                </td>
                                <td>
                                    <div class="small text-muted">Mượn: @item.BorrowDate.ToShortDateString()</div>
                                    <div class="small text-danger fw-bold">Hạn: @item.DueDate.ToShortDateString()</div>
                                </td>
                                <td>
                                    <span class="badge bg-danger rounded-pill px-3">
                                        @item.OverdueDays ngày
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold text-danger">@item.CurrentFine.ToString("C0")</div>
                                </td>
                                <td class="text-end pe-4">
                                    <form asp-action="SendReminder" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-primary btn-sm px-3">
                                            <i class="bi bi-envelope-at me-1"></i> Nhắc trả sách
                                        </button>
                                    </form>
                                    <a asp-controller="BorrowRecords" asp-action="Index" class="btn btn-light btn-sm ms-2">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-check2-circle text-success opacity-25" style="font-size: 5rem;"></i>
            <p class="mt-3 text-muted">Tuyệt vời! Hiện không có sách nào bị quá hạn.</p>
        </div>
    }
</div>
