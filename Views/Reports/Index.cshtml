@model LibraryManagement.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Thống kê - Báo cáo";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-primary fw-bold mb-0">Thống kê & Báo cáo</h1>
        <a asp-action="ExportToExcel" class="btn btn-success">
            <i class="bi bi-file-earmark-excel me-1"></i> Xuất Excel
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 bg-primary text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="opacity-75 small">Tổng số sách</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalBooks</h2>
                    </div>
                    <i class="bi bi-book fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 bg-success text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="opacity-75 small">Tổng độc giả</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalReaders</h2>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 bg-info text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="opacity-75 small">Đang mượn</h6>
                        <h2 class="fw-bold mb-0">@Model.ActiveBorrows</h2>
                    </div>
                    <i class="bi bi-journal-check fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-3 bg-danger text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="opacity-75 small">Đang quá hạn</h6>
                        <h2 class="fw-bold mb-0">@Model.OverdueBorrows</h2>
                    </div>
                    <i class="bi bi-exclamation-triangle fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Chart: Borrowing Trends -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-3 p-4 h-100">
                <h5 class="fw-bold mb-4">Xu hướng mượn sách (6 tháng gần nhất)</h5>
                <canvas id="trendsChart" style="max-height: 300px;"></canvas>
            </div>
        </div>

        <!-- Top Books -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-4 h-100">
                <h5 class="fw-bold mb-4">Top 5 sách mượn nhiều nhất</h5>
                <ul class="list-group list-group-flush">
                    @foreach (var book in Model.TopBorrowedBooks)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-truncate" style="max-width: 200px;">@book.Title</span>
                            <span class="badge bg-primary rounded-pill">@book.BorrowCount lượt</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Most Active Readers -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3 p-4">
                <h5 class="fw-bold mb-4">Độc giả tích cực nhất</h5>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr class="text-muted small">
                                <th>Họ và tên</th>
                                <th class="text-end">Số lượt mượn</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reader in Model.MostActiveReaders)
                            {
                                <tr>
                                    <td>@reader.FullName</td>
                                    <td class="text-end fw-bold text-primary">@reader.BorrowCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('trendsChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.BorrowingTrends.Select(t => t.Month))),
                datasets: [{
                    label: 'Số lượt mượn',
                    data: @Html.Raw(Json.Serialize(Model.BorrowingTrends.Select(t => t.Count))),
                    borderColor: '#4a90e2',
                    backgroundColor: 'rgba(74, 144, 226, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 } }
                }
            }
        });
    </script>
}
