@model IEnumerable<LibraryManagement.Models.Book>
@{
    ViewData["Title"] = "Danh sách sách";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-primary fw-bold mb-0">Thư viện Sách</h1>
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <a asp-action="Create" class="btn btn-primary btn-primary-custom">
                <i class="bi bi-plus-lg"></i> Thêm sách mới
            </a>
        }
    </div>

    <!-- Advanced Filter Bar -->
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Từ khóa</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchTerm" class="form-control border-start-0" placeholder="Tên sách, tác giả..." value="@Context.Request.Query["searchTerm"]">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Thể loại</label>
                    <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
                        <option value="">Tất cả</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Tác giả</label>
                    <select name="author" class="form-select" asp-items="ViewBag.Authors">
                        <option value="">Tất cả</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Tình trạng</label>
                    <select name="status" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="InStock" selected="@(Context.Request.Query["status"] == "InStock")">Còn sách</option>
                        <option value="OutOfStock" selected="@(Context.Request.Query["status"] == "OutOfStock")">Hết sách</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">Lọc</button>
                        <a asp-action="Index" class="btn btn-light" title="Xóa lọc"><i class="bi bi-x-lg"></i></a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Book Grid -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all rounded-3 overflow-hidden">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 300px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 300px;">
                                <i class="bi bi-book text-muted opacity-25" style="font-size: 4rem;"></i>
                            </div>
                        }
                        <span class="position-absolute top-0 end-0 m-2 badge bg-primary">
                            @item.Category?.Name
                        </span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title text-truncate fw-bold mb-1" title="@item.Title">@item.Title</h5>
                        <p class="text-muted small mb-2">@item.Author</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-primary fw-bold">@item.Price.ToString("C0")</span>
                            <span class="small @(item.StockQuantity > 0 ? "text-success" : "text-danger")">
                                @(item.StockQuantity > 0 ? $"Còn {item.StockQuantity}" : "Hết hàng")
                            </span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0 p-3">
                        <div class="d-grid gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm flex-grow-1">Sửa</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100" onclick="return confirm('Bạn có chắc muốn xóa sách này?')">Xóa</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search text-muted opacity-25" style="font-size: 5rem;"></i>
            <p class="mt-3 text-muted">Không tìm thấy cuốn sách nào phù hợp.</p>
        </div>
    }
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
</style>
