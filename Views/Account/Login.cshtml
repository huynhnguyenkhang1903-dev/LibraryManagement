@model LibraryManagement.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="account-page">
    <div class="account-card">
        <h2 class="text-center mb-4">Đăng nhập</h2>
        <form asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <label asp-for="Email"></label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Mật khẩu" />
                <label asp-for="Password"></label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            
            <div class="mb-3 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 btn-primary-custom mb-3">Đăng nhập</button>
            
            <div class="text-center">
                <a asp-action="ForgotPassword" class="text-decoration-none small">Quên mật khẩu?</a>
            </div>
            <hr />
            <div class="text-center">
                <span class="small">Chưa có tài khoản?</span>
                <a asp-action="Register" class="text-decoration-none small fw-bold">Đăng ký ngay</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
