@model LibraryManagement.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="account-page">
    <div class="account-card">
        <h2 class="text-center mb-4">Đổi mật khẩu</h2>
        
        @if (TempData["StatusMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["StatusMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="OldPassword" class="form-control" placeholder="Mật khẩu hiện tại" />
                <label asp-for="OldPassword"></label>
                <span asp-validation-for="OldPassword" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="NewPassword" class="form-control" placeholder="Mật khẩu mới" />
                <label asp-for="NewPassword"></label>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Xác nhận mật khẩu mới" />
                <label asp-for="ConfirmPassword"></label>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 btn-primary-custom mb-3">Đổi mật khẩu</button>
            
            <div class="text-center">
                <a asp-action="Profile" class="text-decoration-none small">Quay lại hồ sơ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
