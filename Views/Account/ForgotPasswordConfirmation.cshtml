@{
    ViewData["Title"] = "Xác nhận quên mật khẩu";
}

<div class="account-page">
    <div class="account-card text-center">
        <h2 class="mb-4">Yêu cầu đã gửi</h2>
        <p class="mb-4">Nếu email của bạn tồn tại trong hệ thống, chúng tôi đã gửi hướng dẫn khôi phục mật khẩu. Vui lòng kiểm tra hộp thư (bao gồm cả thư rác).</p>
        <a asp-action="Login" class="btn btn-primary btn-primary-custom px-4">Quay lại đăng nhập</a>
    </div>
</div>
