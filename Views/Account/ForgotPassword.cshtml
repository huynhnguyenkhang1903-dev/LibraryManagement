@model LibraryManagement.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="account-page">
    <div class="account-card">
        <h2 class="text-center mb-4">Quên mật khẩu</h2>
        <p class="text-muted small text-center mb-4">Nhập email của bạn để nhận hướng dẫn khôi phục mật khẩu.</p>
        
        <form method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <label asp-for="Email"></label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 btn-primary-custom mb-3">Gửi yêu cầu</button>
            
            <div class="text-center">
                <a asp-action="Login" class="text-decoration-none small">Quay lại đăng nhập</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
