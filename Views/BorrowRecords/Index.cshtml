@model IEnumerable<LibraryManagement.Models.BorrowRecord>
@{
    ViewData["Title"] = "Quản lý Mượn/Trả";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-primary fw-bold mb-0">Quản lý Mượn & Trả Sách</h1>
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <a asp-action="Create" class="btn btn-primary btn-primary-custom">
                <i class="bi bi-journal-plus"></i> Tạo phiếu mượn
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Thông tin mượn</th>
                            <th>Độc giả</th>
                            <th>Thời hạn</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary">@item.Book?.Title</div>
                                    <div class="small text-muted">Ngày mượn: @item.BorrowDate.ToShortDateString()</div>
                                </td>
                                <td>
                                    <div>@item.User?.FullName</div>
                                    <div class="small text-muted">@item.User?.Email</div>
                                </td>
                                <td>
                                    <div class="small @(item.Status == "Quá hạn" ? "text-danger fw-bold" : "")">
                                        Hạn trả: @item.DueDate.ToShortDateString()
                                    </div>
                                    @if (item.IsReturned)
                                    {
                                        <div class="small text-success">Đã trả: @item.ReturnDate?.ToShortDateString()</div>
                                    }
                                </td>
                                <td>
                                    @{
                                        string badgeClass = item.Status switch
                                        {
                                            "Đã trả" => "bg-success",
                                            "Quá hạn" => "bg-danger",
                                            _ => "bg-info text-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass">@item.Status</span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (!item.IsReturned && (User.IsInRole("Admin") || User.IsInRole("Staff")))
                                    {
                                        <div class="d-flex justify-content-end gap-2">
                                            <form asp-action="Return" asp-route-id="@item.Id" method="post">
                                                <button type="submit" class="btn btn-success btn-sm px-3">Trả sách</button>
                                            </form>
                                            <form asp-action="Renew" asp-route-id="@item.Id" method="post">
                                                <button type="submit" class="btn btn-outline-secondary btn-sm px-3">Gia hạn</button>
                                            </form>
                                        </div>
                                    }
                                    else if (item.IsReturned)
                                    {
                                        <span class="text-muted small italic">Hoàn tất</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-x text-muted opacity-25" style="font-size: 5rem;"></i>
            <p class="mt-3 text-muted">Chưa có giao dịch mượn trả nào.</p>
        </div>
    }
</div>
