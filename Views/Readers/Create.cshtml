@model LibraryManagement.Models.ApplicationUser
@{
    ViewData["Title"] = "Thêm độc giả mới";
}

<div class="account-page">
    <div class="account-card" style="max-width: 600px;">
        <h2 class="text-center mb-4">Thêm độc giả mới</h2>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>
            
            <div class="row g-3">
                <div class="col-md-12">
                    <div class="form-floating mb-3">
                        <input asp-for="FullName" class="form-control" placeholder="Họ và tên" required />
                        <label asp-for="FullName"></label>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="Email" required />
                        <label asp-for="Email"></label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input type="password" name="password" class="form-control" placeholder="Mật khẩu" required minlength="6" />
                        <label>Mật khẩu</label>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Address" class="form-control" placeholder="Địa chỉ" />
                        <label asp-for="Address"></label>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="LibraryCardNumber" class="form-control" placeholder="Số thẻ thư viện (tùy chọn)" />
                        <label asp-for="LibraryCardNumber"></label>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại" />
                        <label asp-for="PhoneNumber"></label>
                    </div>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 btn-primary-custom mb-3 mt-3">Tạo tài khoản độc giả</button>
            <div class="text-center">
                <a asp-action="Index" class="text-decoration-none small">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
