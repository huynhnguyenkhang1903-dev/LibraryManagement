@model LibraryManagement.Models.ApplicationUser
@{
    ViewData["Title"] = "Sửa thông tin độc giả";
}

<div class="account-page">
    <div class="account-card" style="max-width: 700px;">
        <h2 class="text-center mb-4">Chỉnh sửa thông tin độc giả</h2>
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="FullName" class="form-control" placeholder="Họ và tên" />
                        <label asp-for="FullName"></label>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="Email" readonly />
                        <label asp-for="Email"></label>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Address" class="form-control" placeholder="Địa chỉ" />
                        <label asp-for="Address"></label>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <hr class="my-3">
                    <h5 class="mb-3 text-muted">Thông tin thẻ thư viện</h5>
                </div>

                <div class="col-md-4">
                    <div class="form-floating mb-3">
                        <input asp-for="LibraryCardNumber" class="form-control" placeholder="Số thẻ" />
                        <label asp-for="LibraryCardNumber"></label>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-floating mb-3">
                        <input asp-for="CardIssueDate" type="date" class="form-control" />
                        <label asp-for="CardIssueDate"></label>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-floating mb-3">
                        <input asp-for="CardExpiryDate" type="date" class="form-control" />
                        <label asp-for="CardExpiryDate"></label>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-floating mb-3">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại" />
                        <label asp-for="PhoneNumber"></label>
                    </div>
                </div>
            </div>
            
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary flex-grow-1 btn-primary-custom">Cập nhật thông tin</button>
                <a asp-action="Index" class="btn btn-light px-4">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
