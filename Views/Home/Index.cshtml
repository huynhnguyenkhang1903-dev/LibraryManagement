@model IEnumerable<LibraryManagement.Models.Book>
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<div class="hero-section text-white py-5 mb-5" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); border-radius: 0 0 50px 50px; margin-top: -24px;">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-3 fw-bold mb-4 animate__animated animate__fadeInLeft">Chào mừng bạn đến với Thư viện Hiện đại</h1>
                <p class="lead mb-5 animate__animated animate__fadeInLeft animate__delay-1s">Khám phá hàng ngàn đầu sách hấp dẫn, quản lý mượn trả dễ dàng và trải nghiệm tri thức không giới hạn.</p>
                <div class="d-flex gap-3 animate__animated animate__fadeInUp animate__delay-2s">
                    <a asp-controller="Books" asp-action="Index" class="btn btn-light btn-lg px-5 rounded-pill shadow">Khám phá ngay</a>
                    @if (!User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg px-5 rounded-pill">Đăng ký thành viên</a>
                    }
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center animate__animated animate__fadeInRight">
                <img src="https://cdni.iconscout.com/illustration/premium/thumb/online-library-illustration-download-in-svg-png-gif-file-formats--digital-education-learning-mobile-app-study-pack-people-illustrations-3306283.png?f=webp" alt="Library Illustration" class="img-fluid" style="max-height: 400px; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.3));">
            </div>
        </div>
    </div>
</div>

<div class="container">
    <!-- Featured Books -->
    <div class="section-title mb-4 d-flex justify-content-between align-items-end">
        <div>
            <h2 class="fw-bold text-primary mb-1">Sách mới nhất</h2>
            <p class="text-muted mb-0">Những đầu sách vừa được cập nhật trong thư viện</p>
        </div>
        <a asp-controller="Books" asp-action="Index" class="text-decoration-none fw-bold">Xem tất cả <i class="bi bi-arrow-right"></i></a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
        @foreach (var item in Model)
        {
            <div class="col animate__animated animate__fadeInUp">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all rounded-4 overflow-hidden">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 280px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 280px;">
                                <i class="bi bi-book text-muted opacity-25" style="font-size: 4rem;"></i>
                            </div>
                        }
                        <div class="position-absolute bottom-0 start-0 m-2">
                            <span class="badge bg-primary rounded-pill shadow-sm">@item.Category?.Name</span>
                        </div>
                    </div>
                    <div class="card-body p-3 text-center">
                        <h6 class="card-title text-truncate fw-bold mb-1" title="@item.Title">@item.Title</h6>
                        <p class="text-muted small mb-3">@item.Author</p>
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-pill w-100">Chi tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Features -->
    <div class="row g-4 py-5 border-top">
        <div class="col-md-4">
            <div class="text-center p-4">
                <div class="feature-icon bg-light text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 80px; height: 80px; font-size: 2rem;">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h4 class="fw-bold">Bảo mật & Uy tín</h4>
                <p class="text-muted">Hệ thống quản lý tài khoản và thông tin mượn trả an toàn, minh bạch.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="text-center p-4">
                <div class="feature-icon bg-light text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 80px; height: 80px; font-size: 2rem;">
                    <i class="bi bi-lightning-charge"></i>
                </div>
                <h4 class="fw-bold">Nhanh chóng</h4>
                <p class="text-muted">Tìm kiếm và mượn sách chỉ trong vài giây với giao diện tối ưu.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="text-center p-4">
                <div class="feature-icon bg-light text-info rounded-circle d-inline-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 80px; height: 80px; font-size: 2rem;">
                    <i class="bi bi-headset"></i>
                </div>
                <h4 class="fw-bold">Hỗ trợ 24/7</h4>
                <p class="text-muted">Đội ngũ thủ thư luôn sẵn sàng hỗ trợ bạn mọi lúc, mọi nơi.</p>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

<style>
    .hover-shadow:hover {
        transform: translateY(-10px);
        box-shadow: 0 1.5rem 4rem rgba(0,0,0,.15) !important;
    }
    .transition-all {
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
    .feature-icon i {
        transition: transform 0.3s ease;
    }
    .feature-icon:hover i {
        transform: scale(1.2) rotate(10deg);
    }
</style>
