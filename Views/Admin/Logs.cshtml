@model IEnumerable<LibraryManagement.Models.AuditLog>
@{
    ViewData["Title"] = "Nhật ký hoạt động";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-primary fw-bold mb-0">Nhật ký hoạt động</h1>
        <a asp-action="Index" class="btn btn-light"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Thời gian</th>
                        <th>Người thực hiện</th>
                        <th>Thao tác</th>
                        <th>Đối tượng</th>
                        <th>Chi tiết</th>
                        <th class="pe-4">IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="ps-4 small">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="small fw-bold">@log.User?.FullName</div>
                                <div class="text-muted" style="font-size: 0.7rem;">@log.User?.Email</div>
                            </td>
                            <td><span class="badge bg-secondary">@log.Action</span></td>
                            <td>@log.EntityName</td>
                            <td class="small">@log.Details</td>
                            <td class="pe-4 small text-muted">@log.IpAddress</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
