@{
    ViewData["Title"] = "Quản trị hệ thống";
}

<div class="container py-4">
    <h1 class="h2 text-primary fw-bold mb-4">Quản trị hệ thống</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 h-100 p-4 text-center">
                <i class="bi bi-people-fill text-primary mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold">Quản lý người dùng</h5>
                <p class="text-muted small">Quản lý tất cả tài khoản và phân quyền hệ thống (Admin, Staff, User).</p>
                <a asp-action="Users" class="btn btn-outline-primary mt-auto">Quản lý</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 h-100 p-4 text-center">
                <i class="bi bi-journal-text text-success mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold">Nhật ký hoạt động</h5>
                <p class="text-muted small">Theo dõi các thao tác quan trọng trên hệ thống của người dùng và nhân viên.</p>
                <a asp-action="Logs" class="btn btn-outline-success mt-auto">Xem nhật ký</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 h-100 p-4 text-center">
                <i class="bi bi-database-up text-info mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold">Sao lưu & Phục hồi</h5>
                <p class="text-muted small">Sao lưu cơ sở dữ liệu hiện tại để đảm bảo an toàn dữ liệu.</p>
                <a asp-action="Backup" class="btn btn-outline-info mt-auto">Sao lưu ngay</a>
            </div>
        </div>
    </div>
</div>
