@model IEnumerable<LibraryManagement.Models.ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-primary fw-bold mb-0">Quản lý người dùng & Phân quyền</h1>
        <a asp-action="Index" class="btn btn-light"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Họ tên & Email</th>
                    <th>Ngày tham gia</th>
                    <th>Quyền hiện tại</th>
                    <th class="text-end pe-4">Thay đổi quyền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var roles = await UserManager.GetRolesAsync(user);
                    var currentRole = roles.FirstOrDefault() ?? "N/A";
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold">@user.FullName</div>
                            <div class="small text-muted">@user.Email</div>
                        </td>
                        <td>@user.CreatedAt.ToShortDateString()</td>
                        <td>
                            <span class="badge @(currentRole == "Admin" ? "bg-danger" : currentRole == "Staff" ? "bg-warning text-dark" : "bg-info text-dark")">
                                @currentRole
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <form asp-action="ChangeRole" method="post" class="d-inline-flex gap-2">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="newRole" class="form-select form-select-sm" style="width: 120px;">
                                    <option value="Admin" selected="@(currentRole == "Admin")">Admin</option>
                                    <option value="Staff" selected="@(currentRole == "Staff")">Staff</option>
                                    <option value="User" selected="@(currentRole == "User")">User</option>
                                </select>
                                <button type="submit" class="btn btn-primary btn-sm">Cập nhật</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
