@model IEnumerable<LibraryManagement1.Controllers.OverdueReportRow>

@{
    ViewData["Title"] = "Báo cáo Sách trễ hạn";
    var totalOverdue = Model.Count();
    var stt = 1;
}

<div class="d-flex justify-content-between align-items-center mb-4 d-print-none">
    <div>
        <h2 class="mb-1">Báo Cáo Sách Trễ Hạn</h2>
        <p class="text-secondary mb-0">Thống kê danh sách độc giả mượn sách quá hạn chưa trả</p>
    </div>
    <button onclick="window.print()" class="btn btn-premium-primary">
        <i class="bi bi-printer me-2"></i>In báo cáo
    </button>
</div>

<!-- Print Header (Hidden on screen) -->
<div class="d-none d-print-block text-center mb-5">
    <h3>THƯ VIỆN LIBADMIN PRO</h3>
    <h2>BÁO CÁO DANH SÁCH SÁCH TRỄ HẠN CHƯA TRẢ</h2>
    <p class="text-secondary">Ngày lập báo cáo: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    <hr />
</div>

<div class="glass-panel stat-card danger mb-4 d-print-inline-block w-100">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <span class="text-secondary d-block fs-8 mb-1">Tổng Số Lượt Sách Quá Hạn Chưa Thu Hồi</span>
            <h2 class="fw-bold text-danger mb-0">@totalOverdue <span class="fs-6 fw-normal text-secondary">cuốn sách</span></h2>
        </div>
        <div class="avatar bg-danger text-white rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px;">
            <i class="bi bi-exclamation-triangle-fill fs-4"></i>
        </div>
    </div>
</div>

<div class="glass-panel">
    <h5 class="mb-4 border-bottom pb-2 border-secondary"><i class="bi bi-table text-danger me-2"></i>Chi tiết các lượt mượn quá hạn</h5>
    <div class="table-responsive">
        <table class="custom-table mb-0">
            <thead>
                <tr>
                    <th style="width: 5%;">STT</th>
                    <th style="width: 25%;">Độc giả</th>
                    <th style="width: 35%;">Tên sách / Mã sách</th>
                    <th style="width: 15%;">Ngày mượn</th>
                    <th style="width: 10%;">Trễ hạn (Ngày)</th>
                    <th style="width: 10%;" class="text-end">Phạt ước tính</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-4">Hiện tại không có cuốn sách nào quá hạn. Thật tuyệt vời!</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@(stt++)</td>
                            <td>
                                <div class="fw-bold text-dark">@item.ReaderName</div>
                                <small class="text-secondary fs-8">Mã: @item.ReaderCode | Phiếu: @item.TicketCode</small>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.BookTitle</div>
                                <small class="text-primary fs-8">Mã sách: @item.BookCode</small>
                            </td>
                            <td class="text-secondary">@item.BorrowDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-danger fw-bold">@item.LateDays ngày</td>
                            <td class="text-end fw-bold text-danger">@item.EstimatedFine.ToString("N0") đ</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
