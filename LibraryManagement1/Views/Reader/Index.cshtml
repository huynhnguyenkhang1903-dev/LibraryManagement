@model IEnumerable<LibraryManagement1.Models.Reader>

@{
    ViewData["Title"] = "Quản lý độc giả";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Danh sách Độc giả</h2>
        <p class="text-secondary mb-0">Quản lý tài khoản độc giả và thời hạn thẻ thư viện</p>
    </div>
    <a asp-action="Create" class="btn btn-premium-primary">
        <i class="bi bi-person-plus me-2"></i>Thêm độc giả mới
    </a>
</div>

<!-- Search Panel -->
<div class="glass-panel mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-center">
        <div class="col-md-9">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: var(--border-glass) !important;">
                    <i class="bi bi-search text-secondary"></i>
                </span>
                <input type="text" name="searchString" class="form-control border-start-0 ps-0" placeholder="Tìm theo mã độc giả, tên, số điện thoại, email..." value="@ViewData["CurrentSearch"]" />
            </div>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-premium-primary w-100">Tìm kiếm</button>
            <a asp-action="Index" class="btn btn-premium-secondary"><i class="bi bi-arrow-counterclockwise"></i></a>
        </div>
    </form>
</div>

<!-- Readers List -->
<div class="glass-panel">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 12%;">Mã Độc Giả</th>
                    <th style="width: 25%;">Họ Tên</th>
                    <th style="width: 15%;">Số điện thoại</th>
                    <th style="width: 18%;">Email</th>
                    <th style="width: 15%;">Hạn Thẻ</th>
                    <th style="width: 15%;" class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-5">
                            <i class="bi bi-people-fill fs-1 d-block mb-2"></i>
                            Không tìm thấy độc giả nào.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    var isExpired = item.ExpiryDate < DateTime.Now;
                    var statusClass = isExpired ? "overdue" : "returned";
                    var statusText = isExpired ? "Hết hạn" : "Hoạt động";
                    
                    <tr>
                        <td class="text-primary fw-bold">@item.ReaderCode</td>
                        <td>
                            <div>
                                <div class="fw-bold text-dark">@item.Name</div>
                                <small class="text-secondary">NS: @item.BirthDate.ToString("dd/MM/yyyy")</small>
                            </div>
                        </td>
                        <td class="text-secondary">@item.Phone</td>
                        <td class="text-secondary text-truncate" style="max-width: 180px;">@item.Email</td>
                        <td>
                            <div>
                                <span class="status-badge @statusClass px-2 py-0.5" style="font-size: 0.7rem; margin-bottom: 2px;">
                                    @statusText
                                </span>
                                <div class="text-secondary fs-8">HSD: @item.ExpiryDate.ToString("dd/MM/yyyy")</div>
                            </div>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-premium-secondary me-2">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-premium-danger">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
