@model LibraryManagement1.Models.BorrowDetail

@{
    ViewData["Title"] = "Lập biên lai thu tiền phạt";
    var pendingAmount = (decimal)(ViewData["PendingAmount"] ?? 0m);
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
    <h2 class="mt-2">Lập Biên Lai Thu Tiền Phạt</h2>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="glass-panel">
            <h5 class="mb-4 border-bottom border-secondary pb-2">
                <i class="bi bi-file-earmark-text text-primary me-2"></i>Chi tiết khoản phạt trễ hạn
            </h5>

            <div class="bg-black bg-opacity-20 p-4 rounded-3 border border-secondary mb-4" style="border-color: var(--border-glass) !important;">
                <div class="row mb-3">
                    <div class="col-5 text-secondary">Độc giả:</div>
                    <div class="col-7 text-dark fw-bold">@Model.BorrowTicket?.Reader?.Name</div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-secondary">Mã độc giả:</div>
                    <div class="col-7 text-primary fw-bold">@Model.BorrowTicket?.Reader?.ReaderCode</div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-secondary">Phiếu mượn:</div>
                    <div class="col-7 text-dark">@Model.BorrowTicket?.TicketCode</div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-secondary">Sách mượn trả trễ:</div>
                    <div class="col-7 text-dark font-italic">@Model.Book?.Title</div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-secondary">Hạn trả hẹn trước:</div>
                    <div class="col-7 text-dark">@Model.BorrowTicket?.DueDate.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-secondary">Ngày trả thực tế:</div>
                    <div class="col-7 text-dark">@Model.ReturnDate?.ToString("dd/MM/yyyy")</div>
                </div>
                <hr class="border-secondary my-3" style="opacity: 0.2;" />
                <div class="row">
                    <div class="col-5 text-secondary fw-bold">Tổng tiền phạt trễ:</div>
                    <div class="col-7 text-danger fw-bold fs-5">@Model.FineAmount.ToString("N0") đ</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="glass-panel">
            <h5 class="mb-4 border-bottom border-secondary pb-2">
                <i class="bi bi-wallet2 text-success me-2"></i>Thu tiền phạt
            </h5>

            <form asp-action="Pay" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="borrowTicketId" value="@Model.BorrowTicketId" />
                <input type="hidden" name="readerId" value="@Model.BorrowTicket?.ReaderId" />
                <input type="hidden" name="fineAmount" value="@Model.FineAmount" />

                <div class="mb-3">
                    <label class="form-label">Số tiền còn nợ (VNĐ)</label>
                    <input class="form-control bg-dark border-secondary text-secondary" value="@pendingAmount.ToString("N0") đ" disabled />
                </div>

                <div class="mb-4">
                    <label for="amountPaid" class="form-label">Số tiền thu thực tế (VNĐ)</label>
                    <div class="input-group">
                        <input type="number" name="amountPaid" id="amountPaid" class="form-control" min="1000" max="@pendingAmount" value="@pendingAmount" required />
                        <span class="input-group-text bg-transparent border-start-0 border-secondary text-secondary" style="border-color: var(--border-glass) !important;">VNĐ</span>
                    </div>
                    <small class="text-secondary">Độc giả có thể thanh toán một phần hoặc toàn bộ số tiền phạt.</small>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-premium-primary">
                        <i class="bi bi-receipt me-2"></i>Lập biên lai thu tiền
                    </button>
                    <a asp-action="Index" class="btn btn-premium-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
