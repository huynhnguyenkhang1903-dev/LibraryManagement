@model LibraryManagement1.Models.Publisher

@{
    ViewData["Title"] = "Chỉnh sửa nhà xuất bản";
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <h2 class="text-white mt-2">Chỉnh Sửa Nhà Xuất Bản</h2>
</div>

<div class="glass-panel" style="max-width: 600px;">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="alert alert-custom mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="text-danger fs-7"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger fs-7"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger fs-7"></span>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-premium-primary">
                <i class="bi bi-check-lg me-2"></i>Cập nhật
            </button>
            <a asp-action="Index" class="btn btn-premium-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
