@model LibraryManagement1.Models.Category

@{
    ViewData["Title"] = "Thêm thể loại";
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <h2 class="text-white mt-2">Thêm Thể Loại Mới</h2>
</div>

<div class="glass-panel" style="max-width: 600px;">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="alert alert-custom mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Nhập tên thể loại" required />
            <span asp-validation-for="Name" class="text-danger fs-7"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả ngắn"></textarea>
            <span asp-validation-for="Description" class="text-danger fs-7"></span>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-premium-primary">
                <i class="bi bi-check-lg me-2"></i>Lưu thể loại
            </button>
            <a asp-action="Index" class="btn btn-premium-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
