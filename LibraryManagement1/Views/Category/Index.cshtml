@model IEnumerable<LibraryManagement1.Models.Category>

@{
    ViewData["Title"] = "Thể loại sách";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="text-white mb-1">Thể loại sách</h2>
        <p class="text-secondary mb-0">Quản lý danh sách các thể loại của sách trong thư viện</p>
    </div>
    <a asp-action="Create" class="btn btn-premium-primary">
        <i class="bi bi-plus-lg me-2"></i>Thêm thể loại mới
    </a>
</div>

<div class="glass-panel">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th style="width: 25%;">Tên thể loại</th>
                    <th style="width: 50%;">Mô tả</th>
                    <th style="width: 25%;" class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-secondary py-4">Chưa có thể loại nào được thêm.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-white">@item.Name</td>
                        <td class="text-secondary">@item.Description</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-premium-secondary me-2">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-premium-danger">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
