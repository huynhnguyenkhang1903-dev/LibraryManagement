@model IEnumerable<LibraryManagement1.Models.Book>

@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Trang chủ Thư viện";
    var categories = ViewData["Categories"] as SelectList;
}

<!-- Hero Section -->
<div class="glass-panel text-white border-0 position-relative mb-5 overflow-hidden" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); padding: 4rem 3rem; border-radius: 16px;">
    <!-- Decorative subtle gradient glow -->
    <div class="position-absolute" style="top: -20%; right: -10%; width: 350px; height: 350px; background: radial-gradient(circle, rgba(37, 99, 235, 0.25) 0%, transparent 70%); pointer-events: none; border-radius: 50%;"></div>
    
    <div class="row align-items-center position-relative" style="z-index: 2;">
        <div class="col-lg-7">
            <h1 class="display-5 fw-bold text-white mb-3">Tìm kiếm & Khám phá tri thức</h1>
            <p class="text-white-50 fs-5 mb-4">Chào mừng độc giả đến với cổng thông tin tra cứu sách trực tuyến của **LibAdmin Pro**. Hàng ngàn cuốn sách thuộc nhiều lĩnh vực đang chờ đón bạn.</p>
            <div class="d-flex gap-3">
                <a href="#book-section" class="btn btn-premium-primary py-2.5 px-4"><i class="bi bi-book-half me-2"></i>Tra cứu sách ngay</a>
                <a asp-controller="Home" asp-action="Privacy" class="btn btn-premium-secondary py-2.5 px-4 text-white" style="background: rgba(255, 255, 255, 0.05); border-color: rgba(255,255,255,0.1) !important;"><i class="bi bi-info-circle me-2"></i>Giới thiệu thư viện</a>
            </div>
        </div>
        <div class="col-lg-5 d-none d-lg-block text-center">
            <i class="bi bi-journal-bookmark text-primary" style="font-size: 10rem; filter: drop-shadow(0 10px 15px rgba(37, 99, 235, 0.3));"></i>
        </div>
    </div>
</div>

<!-- Search Panel -->
<div id="book-section" class="glass-panel mb-5 shadow-sm">
    <h4 class="mb-4 text-dark fw-bold"><i class="bi bi-search text-primary me-2"></i>Bộ lọc tìm kiếm sách nhanh</h4>
    <form asp-action="Index" method="get">
        <div class="row g-3">
            <div class="col-md-6 col-lg-5">
                <label class="form-label text-secondary fw-500">Từ khóa tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0" style="border-color: #cbd5e1;">
                        <i class="bi bi-search text-secondary"></i>
                    </span>
                    <input type="text" name="searchString" class="form-control border-start-0 ps-0" placeholder="Nhập tên sách, mã sách hoặc tác giả..." value="@ViewData["CurrentSearch"]" />
                </div>
            </div>
            <div class="col-md-4 col-lg-4">
                <label class="form-label text-secondary fw-500">Thể loại sách</label>
                <select name="categoryId" class="form-select" asp-items="categories">
                    <option value="">-- Tất cả thể loại --</option>
                </select>
            </div>
            <div class="col-md-2 col-lg-3 d-flex align-items-end">
                <div class="d-flex gap-2 w-100">
                    <button type="submit" class="btn btn-premium-primary flex-grow-1">
                        <i class="bi bi-search me-1"></i>Tìm kiếm
                    </button>
                    <a asp-action="Index" class="btn btn-premium-secondary" title="Đặt lại bộ lọc">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Books Grid Section -->
<h3 class="mb-4 fw-bold text-dark d-flex align-items-center justify-content-between">
    <span><i class="bi bi-grid-3x3-gap-fill text-primary me-2"></i>Danh sách sách hiện có</span>
    <span class="fs-7 fw-normal text-secondary">Tìm thấy @Model.Count() kết quả</span>
</h3>

@if (!Model.Any())
{
    <div class="glass-panel text-center py-5 shadow-sm">
        <i class="bi bi-journal-x fs-1 text-secondary mb-3 d-block"></i>
        <h5 class="text-secondary fw-bold">Không tìm thấy sách phù hợp</h5>
        <p class="text-muted mb-0">Thử thay đổi từ khóa tìm kiếm hoặc chọn danh mục khác nhé.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var book in Model)
        {
            var isBookAvailable = book.AvailableQuantity > 0;
            <div class="col">
                <div class="glass-panel card-hover h-100 d-flex flex-column justify-content-between p-3" style="transition: transform 0.2s, box-shadow 0.2s;">
                    <div>
                        <!-- Book top info -->
                        <div class="d-flex gap-3 mb-3">
                            <div class="position-relative flex-shrink-0">
                                <img src="~/images/default_book_cover.png" class="book-thumbnail-large shadow-sm border" alt="Bìa sách" style="width: 75px; height: 105px; object-fit: cover;" />
                            </div>
                            <div>
                                <span class="badge bg-secondary-subtle text-secondary mb-1 px-2 py-1 fs-8 fw-500" style="border: 1px solid var(--border-glass);">
                                    @(book.Category?.Name ?? "Chưa rõ")
                                </span>
                                <h6 class="fw-bold text-dark text-line-clamp-2 mb-1" style="min-height: 2.2rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@book.Title</h6>
                                <p class="text-secondary fs-8 mb-0"><i class="bi bi-person me-1"></i>Tác giả: <strong>@(book.Author?.Name ?? "N/A")</strong></p>
                            </div>
                        </div>
                        
                        <!-- Book meta details -->
                        <hr class="my-2 border-secondary" style="opacity: 0.1;" />
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <span class="text-secondary d-block fs-8">Nhà xuất bản:</span>
                                <span class="text-dark fs-7 fw-500 text-truncate d-block">@(book.Publisher?.Name ?? "N/A")</span>
                            </div>
                            <div class="col-6">
                                <span class="text-secondary d-block fs-8">Năm xuất bản:</span>
                                <span class="text-dark fs-7 fw-500">@book.PublishYear</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Book bottom details / Action -->
                    <div class="d-flex align-items-center justify-content-between pt-2 border-top border-secondary" style="border-top-style: dashed !important; border-top-width: 1px !important; opacity: 0.95;">
                        <div>
                            <span class="status-badge @(isBookAvailable ? "returned" : "overdue") px-2 py-0.5" style="font-size: 0.7rem;">
                                @(isBookAvailable ? $"Còn sách ({book.AvailableQuantity})" : "Hết sách")
                            </span>
                        </div>
                        <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-premium-secondary px-3">
                            <i class="bi bi-info-circle me-1"></i>Chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.1) !important;
        border-color: var(--primary) !important;
    }
</style>
