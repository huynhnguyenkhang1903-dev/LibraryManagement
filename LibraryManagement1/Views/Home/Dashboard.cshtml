@model IEnumerable<LibraryManagement1.Models.BorrowTicket>

@{
    ViewData["Title"] = "Dashboard";
    var totalBooks = ViewData["TotalBooks"];
    var totalReaders = ViewData["TotalReaders"];
    var activeBorrows = ViewData["ActiveBorrows"];
    var overdueTickets = ViewData["OverdueTickets"];
}

<!-- Cozy Banner -->
<div class="cozy-banner">
    <h2 class="fw-bold mb-2">Xin chào, @(User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Thủ thư")!</h2>
    <p class="mb-0 text-white-50 fs-6">Chúc bạn có một ngày làm việc tràn đầy năng lượng tại hệ thống LibAdmin Pro.</p>
</div>

<!-- Stats Grid -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="glass-panel stat-card primary h-100 d-flex flex-column justify-content-between">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="text-secondary d-block fs-7 mb-1">Tổng Đầu Sách</span>
                    <h2 class="text-dark mb-0 fw-bold">@totalBooks</h2>
                </div>
                <div class="avatar bg-primary text-white rounded-3 d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                    <i class="bi bi-book fs-4"></i>
                </div>
            </div>
            <div class="mt-3">
                <div class="progress-bar-glow mb-1">
                    <div class="progress-bar-glow-fill bg-primary" style="width: 80%"></div>
                </div>
                <small class="text-secondary fs-8">Cập nhật thời gian thực</small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="glass-panel stat-card success h-100 d-flex flex-column justify-content-between">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="text-secondary d-block fs-7 mb-1">Tổng Độc Giả</span>
                    <h2 class="text-dark mb-0 fw-bold">@totalReaders</h2>
                </div>
                <div class="avatar bg-success text-white rounded-3 d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                    <i class="bi bi-people fs-4"></i>
                </div>
            </div>
            <div class="mt-3">
                <div class="progress-bar-glow mb-1">
                    <div class="progress-bar-glow-fill bg-success" style="width: 65%"></div>
                </div>
                <small class="text-secondary fs-8">Độc giả đang hoạt động</small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="glass-panel stat-card warning h-100 d-flex flex-column justify-content-between">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="text-secondary d-block fs-7 mb-1">Đang Được Mượn</span>
                    <h2 class="text-dark mb-0 fw-bold">@activeBorrows</h2>
                </div>
                <div class="avatar bg-warning text-white rounded-3 d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                    <i class="bi bi-clipboard-check fs-4"></i>
                </div>
            </div>
            <div class="mt-3">
                <div class="progress-bar-glow mb-1">
                    <div class="progress-bar-glow-fill bg-warning" style="width: 40%"></div>
                </div>
                <small class="text-secondary fs-8">Đang lưu hành ngoài thư viện</small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3">
        <div class="glass-panel stat-card danger h-100 d-flex flex-column justify-content-between">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="text-secondary d-block fs-7 mb-1">Phiếu Quá Hạn</span>
                    <h2 class="mb-0 fw-bold @((int)overdueTickets! > 0 ? "text-danger" : "text-dark")">@overdueTickets</h2>
                </div>
                <div class="avatar bg-danger text-white rounded-3 d-flex justify-content-center align-items-center" style="width: 45px; height: 45px;">
                    <i class="bi bi-exclamation-triangle fs-4"></i>
                </div>
            </div>
            <div class="mt-3">
                <div class="progress-bar-glow mb-1">
                    <div class="progress-bar-glow-fill bg-danger" style="width: @((int)overdueTickets > 0 ? "90%" : "0%")"></div>
                </div>
                <small class="text-secondary fs-8">Yêu cầu thu hồi & xử phạt</small>
            </div>
        </div>
    </div>
</div>

<!-- 12 Modules Grid -->
<div class="mb-4">
    <h5 class="mb-3 fw-bold text-dark"><i class="bi bi-grid-fill text-primary me-2"></i>Hệ thống 12 Phân hệ Chức năng</h5>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-3">
        <!-- 1 -->
        <div class="col">
            <a asp-controller="Home" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-primary-subtle text-primary rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-globe"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">1. Cổng tra cứu sách</h6>
                    <small class="text-secondary fs-8">Trang chủ công cộng</small>
                </div>
            </a>
        </div>
        <!-- 2 -->
        <div class="col">
            <a asp-controller="Home" asp-action="Dashboard" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-secondary-subtle text-dark rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-speedometer2"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">2. Dashboard quản trị</h6>
                    <small class="text-secondary fs-8">Thống kê & Biểu đồ</small>
                </div>
            </a>
        </div>
        <!-- 3 -->
        <div class="col">
            <a asp-controller="Book" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-primary-subtle text-primary rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-journal-bookmark-fill"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">3. Quản lý Sách</h6>
                    <small class="text-secondary fs-8">Kho sách thư viện</small>
                </div>
            </a>
        </div>
        <!-- 4 -->
        <div class="col">
            <a asp-controller="Category" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-success-subtle text-success rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-tags"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">4. Thể loại sách</h6>
                    <small class="text-secondary fs-8">Danh mục phân loại</small>
                </div>
            </a>
        </div>
        <!-- 5 -->
        <div class="col">
            <a asp-controller="Author" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-warning-subtle text-warning rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">5. Tác giả sách</h6>
                    <small class="text-secondary fs-8">Thông tin tác giả</small>
                </div>
            </a>
        </div>
        <!-- 6 -->
        <div class="col">
            <a asp-controller="Publisher" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-info-subtle text-info rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-building"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">6. Nhà xuất bản</h6>
                    <small class="text-secondary fs-8">Đối tác phát hành</small>
                </div>
            </a>
        </div>
        <!-- 7 -->
        <div class="col">
            <a asp-controller="Reader" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-danger-subtle text-danger rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-card-list"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">7. Thẻ Độc giả</h6>
                    <small class="text-secondary fs-8">Tạo & Hạn thẻ thư viện</small>
                </div>
            </a>
        </div>
        <!-- 8 -->
        <div class="col">
            <a asp-controller="Borrow" asp-action="Create" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-success-subtle text-success rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-file-earmark-plus"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">8. Lập phiếu mượn</h6>
                    <small class="text-secondary fs-8">Cho độc giả mượn sách</small>
                </div>
            </a>
        </div>
        <!-- 9 -->
        <div class="col">
            <a asp-controller="Borrow" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-primary-subtle text-primary rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-clipboard-check"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">9. Nhận trả sách</h6>
                    <small class="text-secondary fs-8">Nhận trả & Tính phạt</small>
                </div>
            </a>
        </div>
        <!-- 10 -->
        <div class="col">
            <a asp-controller="Fine" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-warning-subtle text-warning rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-cash-coin"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">10. Thu tiền phạt</h6>
                    <small class="text-secondary fs-8">Lập biên lai nộp phạt</small>
                </div>
            </a>
        </div>
        <!-- 11 -->
        <div class="col">
            <a asp-controller="Report" asp-action="CategoryReport" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                <div class="avatar bg-info-subtle text-info rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold text-dark fs-7">11. Báo cáo thống kê</h6>
                    <small class="text-secondary fs-8">Báo cáo thể loại & trễ hạn</small>
                </div>
            </a>
        </div>
        <!-- 12 -->
        <div class="col">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Setting" asp-action="Index" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                    <div class="avatar bg-danger-subtle text-danger rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                        <i class="bi bi-gear-fill"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold text-dark fs-7">12. Quy định thư viện</h6>
                        <small class="text-secondary fs-8">Cấu hình tham số</small>
                    </div>
                </a>
            }
            else
            {
                <a asp-controller="Home" asp-action="DatabaseSchema" class="glass-panel feature-card d-flex align-items-center gap-3 p-3 h-100 mb-0">
                    <div class="avatar bg-secondary-subtle text-dark rounded-3 d-flex justify-content-center align-items-center shadow-sm" style="width: 42px; height: 42px; font-size: 1.25rem; flex-shrink: 0;">
                        <i class="bi bi-database-fill-gear"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold text-dark fs-7">12. Thiết kế Database</h6>
                        <small class="text-secondary fs-8">Xem cấu trúc bảng</small>
                    </div>
                </a>
            }
        </div>
    </div>
</div>

<style>
    .feature-card {
        transition: var(--transition);
        text-decoration: none !important;
    }
    .feature-card:hover {
        transform: translateY(-3px);
        border-color: var(--primary) !important;
        box-shadow: 0 8px 15px rgba(15, 23, 42, 0.08) !important;
    }
</style>

<!-- Charts Grid -->
<div class="row mb-4">
    <!-- Monthly Borrowings Line Chart -->
    <div class="col-lg-7 mb-3">
        <div class="glass-panel h-100">
            <h5 class="mb-4"><i class="bi bi-graph-up text-primary me-2"></i>Tần suất mượn sách 6 tháng gần nhất</h5>
            <div style="position: relative; height: 280px; width: 100%;">
                <canvas id="monthlyChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Category Distribution Doughnut Chart -->
    <div class="col-lg-5 mb-3">
        <div class="glass-panel h-100">
            <h5 class="mb-4"><i class="bi bi-pie-chart text-success me-2"></i>Cơ cấu sách theo thể loại</h5>
            <div style="position: relative; height: 280px; width: 100%; display: flex; justify-content: center; align-items: center;">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Recent Transactions List -->
<div class="glass-panel">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="bi bi-clock-history text-warning me-2"></i>Hoạt động mượn sách gần đây</h5>
        <a asp-controller="Borrow" asp-action="Index" class="btn btn-sm btn-premium-secondary">Xem tất cả</a>
    </div>

    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Mã phiếu</th>
                    <th>Độc giả</th>
                    <th>Ngày mượn</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-secondary py-3">Chưa có giao dịch mượn sách nào.</td>
                    </tr>
                }
                @foreach (var ticket in Model)
                {
                    var statusClass = ticket.Status == "Returned" ? "returned" : (ticket.Status == "Overdue" ? "overdue" : "borrowing");
                    var statusText = ticket.Status == "Returned" ? "Đã trả đủ" : (ticket.Status == "Overdue" ? "Quá hạn" : "Đang mượn");
                    
                    <tr>
                        <td class="text-primary fw-bold">@ticket.TicketCode</td>
                        <td>
                            <div class="fw-bold text-dark">@ticket.Reader?.Name</div>
                            <small class="text-secondary">Mã ĐG: @ticket.Reader?.ReaderCode</small>
                        </td>
                        <td class="text-secondary">@ticket.BorrowDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="status-badge @statusClass">
                                @statusText
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-controller="Borrow" asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-premium-secondary">
                                Chi tiết
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Chart 1: Line Chart for Monthly borrows
            var monthlyCtx = document.getElementById('monthlyChart').getContext('2d');
            var monthlyChart = new Chart(monthlyCtx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.MonthlyLabels)),
                    datasets: [{
                        label: 'Lượt mượn sách',
                        data: @Html.Raw(Json.Serialize(ViewBag.MonthlyData)),
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37, 99, 235, 0.08)',
                        borderWidth: 3,
                        pointBackgroundColor: '#1d4ed8',
                        pointBorderColor: '#fff',
                        pointHoverRadius: 6,
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            grid: { color: 'rgba(15, 23, 42, 0.06)' },
                            ticks: { color: '#475569', stepSize: 1 }
                        },
                        x: {
                            grid: { color: 'rgba(15, 23, 42, 0.04)' },
                            ticks: { color: '#475569' }
                        }
                    }
                }
            });

            // Chart 2: Doughnut Chart for Category book distributions
            var categoryCtx = document.getElementById('categoryChart').getContext('2d');
            var categoryChart = new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                        backgroundColor: [
                            '#2563eb', /* Primary Blue */
                            '#16a34a', /* Green */
                            '#ea580c', /* Orange */
                            '#dc2626', /* Red */
                            '#64748b'  /* Slate */
                        ],
                        borderColor: '#ffffff',
                        borderWidth: 2,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: {
                                color: '#0f172a',
                                font: { family: 'Outfit', size: 11 }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
