<style>
    /* Schema card custom style */
    .schema-card {
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid var(--border-glass);
    }
    .schema-card:hover {
        transform: translateY(-4px);
        border-color: var(--primary) !important;
        box-shadow: 0 12px 20px rgba(37, 99, 235, 0.08) !important;
    }
    .schema-card.highlighted {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.2), 0 12px 20px rgba(37, 99, 235, 0.08) !important;
        background: #f8fafc;
    }
    .schema-card.dimmed {
        opacity: 0.45;
        filter: grayscale(20%);
    }
    /* Mermaid styling adjustments to match SaaS Slate */
    .mermaid svg {
        max-width: 100% !important;
        height: auto !important;
    }
    .text-slate-900 {
        color: #0f172a !important;
    }
    .text-slate-800 {
        color: #1e293b !important;
    }
</style>

@section Scripts {
    <!-- Load Mermaid JS from CDN -->
    <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <script>
        // Initialize Mermaid with custom style values to fit SaaS Slate theme
        mermaid.initialize({
            startOnLoad: true,
            theme: 'base',
            themeVariables: {
                primaryColor: '#eff6ff',
                primaryTextColor: '#1e293b',
                primaryBorderColor: '#bfdbfe',
                lineColor: '#64748b',
                secondaryColor: '#f8fafc',
                tertiaryColor: '#ffffff',
                mainBkg: '#ffffff',
                actorBkg: '#ffffff',
                actorBorder: '#cbd5e1',
                signalColor: '#2563eb',
                signalTextColor: '#0f172a'
            }
        });

        $(document).ready(function () {
            // Toggle ERD diagram panel visibility
            $("#btn-toggle-diagram").click(function () {
                $("#erd-panel").slideToggle(250);
            });

            // Interactive highlights on table card hover/click
            $(".schema-card").click(function () {
                var container = $(this).closest(".table-card-container");
                var tableName = container.data("table");
                var relationsStr = container.data("relations");
                
                if ($(this).hasClass("highlighted")) {
                    // Reset all
                    $(".schema-card").removeClass("highlighted dimmed");
                } else {
                    // Highlight selected and related cards, dim others
                    $(".schema-card").removeClass("highlighted").addClass("dimmed");
                    $(this).removeClass("dimmed").addClass("highlighted");
                    
                    if (relationsStr && relationsStr !== "none") {
                        var relatedTables = relationsStr.split(" ");
                        relatedTables.forEach(function (rel) {
                            $(".table-card-container[data-table='" + rel + "'] .schema-card")
                                .removeClass("dimmed")
                                .addClass("highlighted");
                        });
                    }
                }
            });

            // Double click anywhere outside to reset highlighting
            $(document).on("click", function (e) {
                if (!$(e.target).closest(".schema-card").length && !$(e.target).closest("#btn-toggle-diagram").length) {
                    $(".schema-card").removeClass("highlighted dimmed");
                }
            });
        });
    </script>
}
