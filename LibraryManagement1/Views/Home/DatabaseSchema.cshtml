                    <div class="d-flex justify-content-between align-items-center py-1">
                        <div>
                            <i class="bi bi-key-fill text-warning me-2" title="Khóa chính"></i><strong>Id</strong>
                        </div>
                        <span class="badge bg-light text-dark fs-8 border">int (PK)</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-1">
                        <div>
                            <span class="ps-4">Username</span>
                        </div>
                        <span class="badge bg-light text-dark fs-8 border">string (Req)</span>
