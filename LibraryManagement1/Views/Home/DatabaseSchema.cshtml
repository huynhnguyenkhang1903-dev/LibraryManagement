@{
    ViewData["Title"] = "Thiết kế Database - LibAdmin Pro";
}

<div class="container-fluid py-4">
    <!-- Header Page -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <span class="badge bg-primary px-3 py-2 mb-2">DATABASE SCHEMA</span>
            <h2 class="mb-1 text-slate-900 fw-bold">Sơ đồ và Cấu trúc Database</h2>
            <p class="text-secondary mb-0">Tra cứu trực quan cấu trúc bảng, kiểu dữ liệu và mối quan hệ thực thể (ERD) trong hệ thống SQLite.</p>
        </div>
        <div class="d-flex gap-2">
            <button id="btn-toggle-diagram" class="btn btn-premium-primary d-flex align-items-center gap-2">
                <i class="bi bi-diagram-3-fill"></i>
                <span>Ẩn/Hiện Sơ đồ ERD</span>
            </button>
        </div>
    </div>

    <!-- ERD Diagram Panel -->
    <div class="glass-panel p-4 mb-4" id="erd-panel">
        <h4 class="fw-bold mb-3 d-flex align-items-center gap-2">
            <i class="bi bi-bezier2 text-primary"></i>
            <span>Sơ đồ Quan hệ Thực thể (ERD)</span>
        </h4>
        <div class="d-flex justify-content-center bg-white p-3 rounded-3 border border-slate-100 overflow-auto">
            <div class="mermaid text-center w-100" style="min-height: 400px;">
                erDiagram
                    Users {
                        int Id PK
                        string Username
                        string PasswordHash
                        string FullName
                        string Role
                    }
                    Categories {
                        int Id PK
                        string Name
                        string Description
                    }
                    Authors {
                        int Id PK
                        string Name
                        string Bio
                        datetime BirthDate
                    }
                    Publishers {
                        int Id PK
                        string Name
                        string Address
                        string Phone
                    }
                    Books {
                        int Id PK
                        string BookCode
                        string Title
                        int CategoryId FK
                        int AuthorId FK
                        int PublisherId FK
                        int PublishYear
                        int Quantity
                        int AvailableQuantity
                        decimal Price
                    }
                    Readers {
                        int Id PK
                        string ReaderCode
                        string Name
                        datetime BirthDate
                        string Address
                        string Phone
                        string Email
                        datetime CreatedDate
                        datetime ExpiryDate
                    }
                    BorrowTickets {
                        int Id PK
                        string TicketCode
                        int ReaderId FK
                        datetime BorrowDate
                        datetime DueDate
                        string Status
                    }
                    BorrowDetails {
                        int Id PK
                        int BorrowTicketId FK
                        int BookId FK
                        datetime ReturnDate
                        decimal FineAmount
                    }
                    FineReceipts {
                        int Id PK
                        string ReceiptCode
                        int ReaderId FK
                        int BorrowTicketId FK
                        decimal FineAmount
                        decimal AmountPaid
                        datetime PaymentDate
                    }

                    Categories ||--o{ Books : "has"
                    Authors ||--o{ Books : "writes"
                    Publishers ||--o{ Books : "publishes"
                    Readers ||--o{ BorrowTickets : "borrows"
                    BorrowTickets ||--|{ BorrowDetails : "contains"
                    Books ||--o{ BorrowDetails : "borrowed_in"
                    Readers ||--o{ FineReceipts : "pays"
                    BorrowTickets ||--o{ FineReceipts : "associated_with"
            </div>
        </div>
    </div>

    <!-- Interactive Table Grid -->
    <h4 class="fw-bold mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-grid-3x3-gap-fill text-primary"></i>
        <span>Chi tiết Cấu trúc 9 Bảng</span>
    </h4>
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
