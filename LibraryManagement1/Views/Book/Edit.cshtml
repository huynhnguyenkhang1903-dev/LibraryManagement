@model LibraryManagement1.Models.Book

@{
    ViewData["Title"] = "Chỉnh sửa sách";
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <h2 class="text-white mt-2">Chỉnh Sửa Sách</h2>
</div>

<div class="glass-panel">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="alert alert-custom mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="AvailableQuantity" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="BookCode" class="form-label">Mã sách</label>
                <input asp-for="BookCode" class="form-control" required />
                <span asp-validation-for="BookCode" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Title" class="form-label">Tên sách</label>
                <input asp-for="Title" class="form-control" required />
                <span asp-validation-for="Title" class="text-danger fs-7"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="CategoryId" class="form-label">Thể loại</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId" required></select>
                <span asp-validation-for="CategoryId" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="AuthorId" class="form-label">Tác giả</label>
                <select asp-for="AuthorId" class="form-select" asp-items="ViewBag.AuthorId" required></select>
                <span asp-validation-for="AuthorId" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="PublisherId" class="form-label">Nhà xuất bản</label>
                <select asp-for="PublisherId" class="form-select" asp-items="ViewBag.PublisherId" required></select>
                <span asp-validation-for="PublisherId" class="text-danger fs-7"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="PublishYear" class="form-label">Năm xuất bản</label>
                <input asp-for="PublishYear" class="form-control" type="number" required />
                <span asp-validation-for="PublishYear" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Quantity" class="form-label">Tổng số lượng</label>
                <input asp-for="Quantity" class="form-control" type="number" min="0" required />
                <span asp-validation-for="Quantity" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Price" class="form-label">Giá tiền (VNĐ)</label>
                <input asp-for="Price" class="form-control" type="number" min="0" required />
                <span asp-validation-for="Price" class="text-danger fs-7"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Số lượng khả dụng (Đang trong kho)</label>
                <input class="form-control bg-dark border-secondary text-secondary" value="@Model.AvailableQuantity" disabled />
                <small class="text-secondary">Số lượng này tự động thay đổi khi mượn/trả sách.</small>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12 mb-3">
                <label asp-for="ImageUrl" class="form-label">Đường dẫn ảnh bìa sách (URL)</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="Ví dụ: https://example.com/cover.jpg (Để trống sẽ dùng ảnh mặc định)" />
                <span asp-validation-for="ImageUrl" class="text-danger fs-7"></span>
            </div>
        </div>

        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-premium-primary">
                <i class="bi bi-check-lg me-2"></i>Cập nhật
            </button>
            <a asp-action="Index" class="btn btn-premium-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
