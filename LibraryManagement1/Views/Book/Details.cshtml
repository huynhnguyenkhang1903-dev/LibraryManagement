@model LibraryManagement1.Models.Book

@{
    ViewData["Title"] = "Chi tiết sách";
    var activeBorrows = ViewBag.ActiveBorrows as IEnumerable<LibraryManagement1.Models.BorrowDetail> ?? new List<LibraryManagement1.Models.BorrowDetail>();
    var pastBorrows = ViewBag.PastBorrows as IEnumerable<LibraryManagement1.Models.BorrowDetail> ?? new List<LibraryManagement1.Models.BorrowDetail>();
    var isAvailable = Model.AvailableQuantity > 0;

    if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Staff")))
    {
        Layout = "_Layout";
    }
    else
    {
        Layout = "_PublicLayout";
    }
}

<div class="mb-4">
    @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Staff")))
    {
        <a asp-action="Index" class="text-secondary text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách sách
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> Quay lại trang chủ
        </a>
    }
    <h2 class="mt-2">Chi Tiết Sách: @Model.Title</h2>
</div>

<div class="row">
    <!-- Left panel: Cover, Status and Quick Actions -->
    <div class="col-lg-4">
        <div class="glass-panel text-center mb-4">
            <div class="position-relative d-inline-block mb-3">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? Url.Content("~/images/default_book_cover.png") : Model.ImageUrl)" class="book-thumbnail-large img-thumbnail" alt="Bìa sách" style="width: 150px; height: 210px; object-fit: cover;" />
                @if (isAvailable)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success px-2 py-1" style="font-size: 0.75rem;">
                        Còn sách
                    </span>
                }
                else
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger px-2 py-1" style="font-size: 0.75rem;">
                        Hết sách
                    </span>
                }
            </div>

            <h5 class="fw-bold mb-1">@Model.Title</h5>
            <p class="text-secondary fs-8 mb-4">Mã sách: <span class="text-primary fw-bold">@Model.BookCode</span></p>

            @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Staff")))
            {
                <div class="d-flex flex-column gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-premium-primary">
                        <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa thông tin
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-premium-danger">
                        <i class="bi bi-trash me-2"></i>Xóa cuốn sách này
                    </a>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-2">
                    @if (isAvailable)
                    {
                        <a asp-controller="Borrow" asp-action="CustomerBorrow" asp-route-bookId="@Model.Id" class="btn btn-premium-primary">
                            <i class="bi bi-bookmark-plus-fill me-2"></i>Mượn cuốn sách này
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary border-0 text-muted w-100" disabled style="background: rgba(0,0,0,0.05);">
                            <i class="bi bi-bookmark-x-fill me-2"></i>Hết sách khả dụng
                        </button>
                    }
                </div>
            }
        </div>

        <div class="glass-panel">
            <h5 class="mb-3 border-bottom border-secondary pb-2">
                <i class="bi bi-shield-check text-primary me-2"></i>Trạng thái kho sách
            </h5>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-secondary fs-8">Tổng số lượng nhập:</span>
                <span class="fw-bold text-dark fs-6">@Model.Quantity cuốn</span>
            </div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-secondary fs-8">Đang có tại thư viện:</span>
                <span class="fw-bold text-success fs-6">@Model.AvailableQuantity cuốn</span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-secondary fs-8">Đang được mượn:</span>
                <span class="fw-bold text-warning fs-6">@(Model.Quantity - Model.AvailableQuantity) cuốn</span>
            </div>
        </div>
    </div>

    <!-- Right panel: Book details metadata -->
    <div class="col-lg-8">
        <div class="glass-panel h-100 mb-0">
            <h5 class="mb-4 border-bottom border-secondary pb-2">
                <i class="bi bi-info-circle-fill text-primary me-2"></i>Thông tin chi tiết
            </h5>

            <div class="row g-4">
                <div class="col-md-6">
                    <span class="text-secondary d-block fs-8 mb-1">Tên sách</span>
                    <span class="text-dark fw-bold fs-6">@Model.Title</span>
                </div>
                <div class="col-md-6">
                    <span class="text-secondary d-block fs-8 mb-1">Mã sách</span>
                    <span class="text-primary fw-bold fs-6">@Model.BookCode</span>
                </div>

                <div class="col-md-6">
                    <span class="text-secondary d-block fs-8 mb-1">Tác giả</span>
                    <span class="text-dark fw-500 fs-6">
                        @if (Model.Author != null)
                        {
                            <span class="fw-bold">@Model.Author.Name</span>
                            @if (!string.IsNullOrEmpty(Model.Author.Bio))
                            {
                                <small class="text-secondary d-block" style="font-size: 0.75rem;">@Model.Author.Bio</small>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Chưa cập nhật</span>
                        }
                    </span>
                </div>
                <div class="col-md-6">
                    <span class="text-secondary d-block fs-8 mb-1">Thể loại</span>
                    <span class="badge bg-secondary-subtle text-secondary px-3 py-2 fs-7 fw-500" style="border: 1px solid var(--border-glass);">
                        @(Model.Category?.Name ?? "Chưa cập nhật")
                    </span>
                </div>

                <div class="col-md-6">
                    <span class="text-secondary d-block fs-8 mb-1">Nhà xuất bản</span>
                    <span class="text-dark fw-500 fs-6">@(Model.Publisher?.Name ?? "Chưa cập nhật")</span>
                </div>
                <div class="col-md-6">
                    <span class="text-secondary d-block fs-8 mb-1">Năm xuất bản</span>
                    <span class="text-dark fs-6">@Model.PublishYear</span>
                </div>

                <div class="col-md-6">
                    <span class="text-secondary d-block fs-8 mb-1">Giá sách</span>
                    <span class="text-primary fw-bold fs-5">@Model.Price.ToString("N0") đ</span>
                </div>
                <div class="col-md-6">
                    <span class="text-secondary d-block fs-8 mb-1">Tình trạng khả dụng</span>
                    <span class="status-badge @(isAvailable ? "returned" : "overdue") px-2 py-0.5 mt-1">
                        @(isAvailable ? $"Sẵn có ({Model.AvailableQuantity})" : "Hết sách")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

@if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Staff")))
{
    <!-- Active Borrows Section -->
    <div class="glass-panel mt-4">
        <h5 class="mb-3 border-bottom border-secondary pb-2">
            <i class="bi bi-hourglass-split text-primary me-2"></i>Độc giả đang mượn cuốn sách này
        </h5>

        <div class="table-responsive">
            <table class="custom-table mb-0">
                <thead>
                    <tr>
                        <th style="width: 25%;">Độc giả</th>
                        <th style="width: 20%;">Mã phiếu mượn</th>
                        <th style="width: 20%;">Ngày mượn</th>
                        <th style="width: 20%;">Hạn trả</th>
                        <th style="width: 15%;" class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!activeBorrows.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-secondary py-4">
                                <i class="bi bi-info-circle fs-2 d-block mb-1"></i>
                                Hiện tại không có độc giả nào mượn cuốn sách này.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in activeBorrows)
                        {
                            var ticket = item.BorrowTicket;
                            var reader = ticket?.Reader;
                            var isOverdue = ticket != null && ticket.Status == "Overdue";
                            
                            <tr>
                                <td>
                                    <div>
                                        <span class="text-dark fw-bold">@(reader?.Name ?? "N/A")</span>
                                        <div class="text-secondary fs-8">Mã ĐG: @(reader?.ReaderCode ?? "N/A")</div>
                                    </div>
                                </td>
                                <td>
                                    <a asp-controller="Borrow" asp-action="Details" asp-route-id="@(ticket?.Id)" class="fw-bold text-decoration-none text-primary">
                                        @(ticket?.TicketCode ?? "N/A")
                                    </a>
                                </td>
                                <td>@(ticket?.BorrowDate.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td class="@(isOverdue ? "text-danger fw-bold" : "")">
                                    @(ticket?.DueDate.ToString("dd/MM/yyyy") ?? "N/A")
                                    @if (isOverdue)
                                    {
                                        <span class="badge bg-danger ms-1" style="font-size: 0.65rem;">Quá hạn</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Borrow" asp-action="Details" asp-route-id="@(ticket?.Id)" class="btn btn-sm btn-premium-secondary">
                                        <i class="bi bi-eye"></i> Xem phiếu mượn
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Past Borrows Section -->
    <div class="glass-panel mt-4">
        <h5 class="mb-3 border-bottom border-secondary pb-2">
            <i class="bi bi-clock-history text-primary me-2"></i>Lịch sử mượn trả gần đây (Tối đa 10 lượt)
        </h5>

        <div class="table-responsive">
            <table class="custom-table mb-0">
                <thead>
                    <tr>
                        <th style="width: 25%;">Độc giả</th>
                        <th style="width: 20%;">Mã phiếu mượn</th>
                        <th style="width: 20%;">Ngày mượn</th>
                        <th style="width: 20%;">Ngày trả thực tế</th>
                        <th style="width: 15%;" class="text-end">Tiền phạt</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!pastBorrows.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-secondary py-4">
                                <i class="bi bi-info-circle fs-2 d-block mb-1"></i>
                                Cuốn sách này chưa từng được trả lại (chưa có lịch sử mượn hoàn thành).
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in pastBorrows)
                        {
                            var ticket = item.BorrowTicket;
                            var reader = ticket?.Reader;
                            
                            <tr>
                                <td>
                                    <div>
                                        <span class="text-dark fw-bold">@(reader?.Name ?? "N/A")</span>
                                        <div class="text-secondary fs-8">Mã ĐG: @(reader?.ReaderCode ?? "N/A")</div>
                                    </div>
                                </td>
                                <td>
                                    <a asp-controller="Borrow" asp-action="Details" asp-route-id="@(ticket?.Id)" class="fw-bold text-decoration-none text-primary">
                                        @(ticket?.TicketCode ?? "N/A")
                                    </a>
                                </td>
                                <td>@(ticket?.BorrowDate.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td>
                                    <span class="text-success fw-500">
                                        <i class="bi bi-check-circle me-1"></i>@(item.ReturnDate?.ToString("dd/MM/yyyy") ?? "N/A")
                                    </span>
                                </td>
                                <td class="text-end fw-bold @(item.FineAmount > 0 ? "text-danger" : "text-secondary")">
                                    @(item.FineAmount > 0 ? $"{item.FineAmount.ToString("N0")} đ" : "0 đ")
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
