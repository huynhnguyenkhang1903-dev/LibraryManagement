@model LibraryManagement1.Models.Book

@{
    ViewData["Title"] = "Thêm sách";
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <h2 class="text-white mt-2">Thêm Sách Mới</h2>
</div>

<div class="glass-panel">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="alert alert-custom mb-3"></div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="BookCode" class="form-label">Mã sách</label>
                <input asp-for="BookCode" class="form-control" placeholder="Ví dụ: MS001" required />
                <span asp-validation-for="BookCode" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Title" class="form-label">Tên sách</label>
                <input asp-for="Title" class="form-control" placeholder="Nhập tên sách" required />
                <span asp-validation-for="Title" class="text-danger fs-7"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="CategoryId" class="form-label">Thể loại</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId" required>
                    <option value="">-- Chọn thể loại --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="AuthorId" class="form-label">Tác giả</label>
                <select asp-for="AuthorId" class="form-select" asp-items="ViewBag.AuthorId" required>
                    <option value="">-- Chọn tác giả --</option>
                </select>
                <span asp-validation-for="AuthorId" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="PublisherId" class="form-label">Nhà xuất bản</label>
                <select asp-for="PublisherId" class="form-select" asp-items="ViewBag.PublisherId" required>
                    <option value="">-- Chọn nhà xuất bản --</option>
                </select>
                <span asp-validation-for="PublisherId" class="text-danger fs-7"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="PublishYear" class="form-label">Năm xuất bản</label>
                <input asp-for="PublishYear" class="form-control" type="number" placeholder="Ví dụ: 2024" required />
                <span asp-validation-for="PublishYear" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Quantity" class="form-label">Tổng số lượng</label>
                <input asp-for="Quantity" class="form-control" type="number" min="0" placeholder="Nhập số lượng sách" required />
                <span asp-validation-for="Quantity" class="text-danger fs-7"></span>
            </div>

            <div class="col-md-4 mb-3">
                <label asp-for="Price" class="form-label">Giá tiền (VNĐ)</label>
                <input asp-for="Price" class="form-control" type="number" min="0" placeholder="Nhập giá sách" required />
                <span asp-validation-for="Price" class="text-danger fs-7"></span>
            </div>
        </div>

        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-premium-primary">
                <i class="bi bi-check-lg me-2"></i>Lưu sách
            </button>
            <a asp-action="Index" class="btn btn-premium-secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
