@{
    Layout = "_Layout";
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="login-wrapper">
    <div class="login-card text-center shadow-lg" style="max-width: 480px; width: 100%;">
        <div class="mb-4">
            <i class="bi bi-person-plus-fill" style="font-size: 3.5rem; color: var(--primary) !important;"></i>
            <h2 class="mt-3 mb-1">Đăng Ký Tài Khoản</h2>
            <p class="text-secondary fs-6">Đăng ký để tra cứu và lưu lịch sử mượn sách</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-custom mb-3 text-start">
                <ul class="mb-0 ps-3">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Register" method="post" class="text-start">
            @Html.AntiForgeryToken()
            
            <div class="mb-3">
                <label for="username" class="form-label">Tên đăng nhập</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: var(--border-glass) !important;">
                        <i class="bi bi-person text-secondary"></i>
                    </span>
                    <input type="text" class="form-control border-start-0 ps-0" id="username" name="username" placeholder="Nhập tài khoản đăng ký" required autofocus />
                </div>
            </div>

            <div class="mb-3">
                <label for="fullName" class="form-label">Họ và tên</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: var(--border-glass) !important;">
                        <i class="bi bi-card-text text-secondary"></i>
                    </span>
                    <input type="text" class="form-control border-start-0 ps-0" id="fullName" name="fullName" placeholder="Nhập họ và tên của bạn" required />
                </div>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: var(--border-glass) !important;">
                        <i class="bi bi-lock text-secondary"></i>
                    </span>
                    <input type="password" class="form-control border-start-0 ps-0" id="password" name="password" placeholder="Nhập mật khẩu" required />
                </div>
            </div>

            <div class="mb-4">
                <label for="confirmPassword" class="form-label">Xác nhận mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: var(--border-glass) !important;">
                        <i class="bi bi-shield-lock text-secondary"></i>
                    </span>
                    <input type="password" class="form-control border-start-0 ps-0" id="confirmPassword" name="confirmPassword" placeholder="Nhập lại mật khẩu" required />
                </div>
            </div>

            <button type="submit" class="btn btn-premium-primary w-100 py-2.5 fs-5">
                Đăng ký tài khoản
            </button>
        </form>

        <div class="mt-4 text-center">
            <span class="text-secondary fs-7">Đã có tài khoản?</span>
            <a asp-action="Login" class="text-primary fs-7 text-decoration-none fw-bold ms-1">Đăng nhập ngay</a>
        </div>

        <div class="mt-4 pt-3 border-top border-secondary" style="opacity: 0.3;">
            <p class="text-secondary fs-8 mb-0">&copy; 2026 LibAdmin. All rights reserved.</p>
        </div>
    </div>
</div>
