@{
    Layout = "_Layout";
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-wrapper">
    <div class="login-card text-center shadow-lg">
        <div class="mb-4">
            <i class="bi bi-book-half" style="font-size: 3.5rem; color: var(--primary) !important;"></i>
            <h2 class="mt-3 mb-1">LibAdmin Pro</h2>
            <p class="text-secondary fs-6">Hệ thống Quản lý Thư viện Ấm cúng</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-custom mb-3 text-start">
                <ul class="mb-0 ps-3">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Login" method="post" class="text-start">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="username" class="form-label">Tên đăng nhập</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: var(--border-glass) !important;">
                        <i class="bi bi-person text-secondary"></i>
                    </span>
                    <input type="text" class="form-control border-start-0 ps-0" id="username" name="username" placeholder="Nhập tài khoản" required autofocus />
                </div>
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: var(--border-glass) !important;">
                        <i class="bi bi-lock text-secondary"></i>
                    </span>
                    <input type="password" class="form-control border-start-0 ps-0" id="password" name="password" placeholder="Nhập mật khẩu" required />
                </div>
            </div>

            <button type="submit" class="btn btn-premium-primary w-100 py-2.5 fs-5">
                Đăng nhập
            </button>
        </form>

        <div class="mt-4 pt-3 border-top border-secondary" style="opacity: 0.3;">
            <p class="text-secondary fs-8 mb-0">&copy; 2026 LibAdmin. All rights reserved.</p>
        </div>
    </div>
</div>
