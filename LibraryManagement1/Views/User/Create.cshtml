@model LibraryManagement1.Models.User

@{
    ViewData["Title"] = "Thêm Nhân viên";
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <h2 class="mt-2">Thêm Nhân Viên Mới</h2>
</div>

<div class="row">
    <div class="col-lg-8 col-xl-6">
        <div class="glass-panel">
            <h5 class="mb-4 border-bottom pb-2 border-secondary"><i class="bi bi-person-plus text-primary me-2"></i>Thông tin tài khoản</h5>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-custom mb-4">
                        <ul class="mb-0 ps-3">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Tên đăng nhập</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: #cbd5e1 !important;">
                            <i class="bi bi-person text-secondary"></i>
                        </span>
                        <input asp-for="Username" class="form-control border-start-0 ps-0" placeholder="Ví dụ: nguyenvanb" required />
                    </div>
                    <span asp-validation-for="Username" class="text-danger fs-8"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Họ và tên</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: #cbd5e1 !important;">
                            <i class="bi bi-card-text text-secondary"></i>
                        </span>
                        <input asp-for="FullName" class="form-control border-start-0 ps-0" placeholder="Ví dụ: Nguyễn Văn B" required />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger fs-8"></span>
                </div>

                <div class="mb-3">
                    <label for="clearPassword" class="form-label">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: #cbd5e1 !important;">
                            <i class="bi bi-lock text-secondary"></i>
                        </span>
                        <input type="password" id="clearPassword" name="clearPassword" class="form-control border-start-0 ps-0" placeholder="Nhập mật khẩu" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label">Quyền hạn / Vai trò</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: #cbd5e1 !important;">
                            <i class="bi bi-shield-check text-secondary"></i>
                        </span>
                        <select asp-for="Role" class="form-select border-start-0 ps-0">
                            <option value="Staff">Thủ thư (Staff)</option>
                            <option value="Admin">Quản trị viên (Admin)</option>
                        </select>
                    </div>
                    <span asp-validation-for="Role" class="text-danger fs-8"></span>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-premium-primary flex-grow-1">
                        <i class="bi bi-check-lg me-1"></i>Lưu tài khoản
                    </button>
                    <a asp-action="Index" class="btn btn-premium-secondary px-4">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>
