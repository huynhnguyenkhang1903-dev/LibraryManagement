@model LibraryManagement1.Models.User

@{
    ViewData["Title"] = "Chỉnh sửa Nhân viên";
}

<div class="mb-4">
    <a asp-action="Index" class="text-secondary text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <h2 class="mt-2">Chỉnh Sửa Tài Khoản Nhân Viên</h2>
</div>

<div class="row">
    <div class="col-lg-8 col-xl-6">
        <div class="glass-panel">
            <h5 class="mb-4 border-bottom pb-2 border-secondary"><i class="bi bi-pencil-square text-primary me-2"></i>Thông tin tài khoản: @Model.Username</h5>

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Username" />
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-custom mb-4">
                        <ul class="mb-0 ps-3">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label text-secondary">Tên đăng nhập (Không thể thay đổi)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 border-secondary" style="border-color: #cbd5e1 !important;">
                            <i class="bi bi-person text-muted"></i>
                        </span>
                        <input class="form-control bg-light border-start-0 ps-0 text-muted" value="@Model.Username" readonly />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Họ và tên</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: #cbd5e1 !important;">
                            <i class="bi bi-card-text text-secondary"></i>
                        </span>
                        <input asp-for="FullName" class="form-control border-start-0 ps-0" placeholder="Nhập họ tên" required />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger fs-8"></span>
                </div>

                <div class="mb-3">
                    <label for="newPassword" class="form-label">Mật khẩu mới (Để trống nếu không muốn đổi)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: #cbd5e1 !important;">
                            <i class="bi bi-lock text-secondary"></i>
                        </span>
                        <input type="password" id="newPassword" name="newPassword" class="form-control border-start-0 ps-0" placeholder="Nhập mật khẩu mới" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Role" class="form-label">Quyền hạn / Vai trò</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 border-secondary" style="border-color: #cbd5e1 !important;">
                            <i class="bi bi-shield-check text-secondary"></i>
                        </span>
                        @if (Model.Username.Equals(User.Identity?.Name, StringComparison.OrdinalIgnoreCase))
                        {
                            <!-- Prevent editing own role to avoid self-lockout -->
                            <input type="hidden" asp-for="Role" />
                            <select class="form-select border-start-0 ps-0 text-muted bg-light" disabled>
                                <option value="Admin" selected>Quản trị viên (Admin) - Không thể tự đổi quyền</option>
                            </select>
                        }
                        else
                        {
                            <select asp-for="Role" class="form-select border-start-0 ps-0">
                                <option value="User">Người dùng (User)</option>
                                <option value="Staff">Thủ thư (Staff)</option>
                                <option value="Admin">Quản trị viên (Admin)</option>
                            </select>
                        }
                    </div>
                    <span asp-validation-for="Role" class="text-danger fs-8"></span>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-premium-primary flex-grow-1">
                        <i class="bi bi-check-lg me-1"></i>Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-premium-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
